---
import Base from "@layouts/Base.astro";
import Icon from "@components/Icon.astro";
---
<Base title="Page not found" noindex={true}>
  <section class="section nf">
    <div class="container nf__inner">
      <p class="nf__crumbs" aria-hidden="true">404</p>
      <h1>This page is still proofing.</h1>
      <p class="lede prose center">
        We couldn't find what you were looking for — but there's always something
        warm out of the oven. Let's get you back to the good stuff.
      </p>
      <div class="nf__actions">
        <a href="/menu" class="btn btn--primary btn--lg">See the menu <Icon name="arrow" size={18} /></a>
        <a href="/" class="btn btn--ghost btn--lg">Back home</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .nf {
    min-height: 60vh;
    display: grid;
    place-items: center;
    text-align: center;
  }
  .nf__inner {
    max-width: 40rem;
  }
  .nf__crumbs {
    font-family: var(--font-display);
    font-size: clamp(5rem, 20vw, 11rem);
    line-height: 0.9;
    color: color-mix(in oklab, var(--gold) 45%, transparent);
  }
  .nf .lede {
    margin: 1rem auto 0;
  }
  .nf__actions {
    display: flex;
    gap: 0.8rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 2rem;
  }
</style>
