---
import Base from "@layouts/Base.astro";
import Icon from "@components/Icon.astro";
import { site } from "@data/site";
---
<Base title="Thank you" description="Your order is in. Thank you for pulling up a chair." noindex={true}>
  <section class="section thanks">
    <div class="container thanks__inner">
      <div class="thanks__mark" aria-hidden="true">
        <Icon name="check" size={40} />
      </div>
      <p class="eyebrow center" lang="am">{site.amharic.peace}</p>
      <h1>Thank you for pulling up a chair.</h1>
      <p class="lede prose center">
        Your order is in and our bakers are already on it. A confirmation is on its
        way to your inbox — keep an eye out for pickup or delivery details.
      </p>

      <div class="thanks__summary" data-order-summary hidden>
        <h2>Order summary</h2>
        <div data-order-lines></div>
        <div class="thanks__total">
          <span>Total</span><strong data-order-total></strong>
        </div>
        <p class="thanks__ref">Reference: <span data-order-ref></span></p>
      </div>

      <div class="thanks__actions">
        <a href="/menu" class="btn btn--primary btn--lg">Back to the menu</a>
        <a href="/" class="btn btn--ghost btn--lg">Home</a>
      </div>

      <p class="thanks__note">
        Questions about your order? Email
        <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a> or call
        <a href={site.contact.phoneHref}>{site.contact.phone}</a>.
      </p>
    </div>
  </section>
</Base>

<script>
  // Clear the basket once an order completes, and try to show a summary.
  import { formatPrice } from "@data/menu";
  try {
    localStorage.removeItem("selam-cart-v1");
  } catch {}
  const badge = document.querySelector<HTMLElement>("[data-cart-count]");
  if (badge) {
    badge.hidden = true;
    badge.textContent = "0";
  }

  const params = new URLSearchParams(location.search);
  const sessionId = params.get("session_id");
  if (sessionId) {
    fetch(`/api/order?session_id=${encodeURIComponent(sessionId)}`)
      .then((r) => (r.ok ? r.json() : Promise.reject()))
      .then((order: any) => {
        if (!order || !order.items) return;
        const box = document.querySelector<HTMLElement>("[data-order-summary]");
        const lines = document.querySelector<HTMLElement>("[data-order-lines]");
        const total = document.querySelector<HTMLElement>("[data-order-total]");
        const ref = document.querySelector<HTMLElement>("[data-order-ref]");
        if (lines)
          lines.innerHTML = order.items
            .map(
              (it: any) =>
                `<div class="thanks__line"><span>${it.quantity} × ${it.name}</span><span>${formatPrice(
                  it.unit_price_cents * it.quantity
                )}</span></div>`
            )
            .join("");
        if (total) total.textContent = formatPrice(order.total_cents ?? 0);
        if (ref) ref.textContent = (order.id ?? "").slice(0, 8);
        if (box) box.hidden = false;
      })
      .catch(() => {});
  }
</script>

<style>
  .thanks {
    min-height: 60vh;
    display: grid;
    place-items: center;
  }
  .thanks__inner {
    max-width: 42rem;
    text-align: center;
  }
  .thanks__mark {
    width: 5rem;
    height: 5rem;
    margin: 0 auto 1.5rem;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: color-mix(in oklab, var(--green) 18%, var(--cream));
    color: var(--green);
    animation: pop 0.6s var(--ease);
  }
  @keyframes pop {
    from {
      transform: scale(0.6);
      opacity: 0;
    }
  }
  .thanks h1 {
    margin-top: 0.4rem;
  }
  .thanks .lede {
    margin: 1rem auto 0;
  }
  .thanks__summary {
    text-align: left;
    margin: 2.5rem auto 0;
    max-width: 28rem;
    background: var(--surface);
    border: 1px solid color-mix(in oklab, var(--ink) 8%, transparent);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
  }
  .thanks__summary h2 {
    font-size: var(--step-1);
    margin-bottom: 1rem;
  }
  :global(.thanks__line) {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.4rem 0;
    color: var(--muted);
  }
  .thanks__total {
    display: flex;
    justify-content: space-between;
    margin-top: 0.8rem;
    padding-top: 0.8rem;
    border-top: 1px solid color-mix(in oklab, var(--ink) 10%, transparent);
    font-size: var(--step-1);
  }
  .thanks__total strong {
    font-family: var(--font-display);
    color: var(--berbere);
  }
  .thanks__ref {
    margin-top: 0.8rem;
    font-size: var(--step--1);
    color: var(--ink-faint);
  }
  .thanks__actions {
    display: flex;
    gap: 0.8rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 2rem;
  }
  .thanks__note {
    margin-top: 2rem;
    font-size: var(--step--1);
    color: var(--ink-faint);
  }
</style>
