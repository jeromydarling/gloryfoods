---
import Base from "@layouts/Base.astro";
import Icon from "@components/Icon.astro";
import ProductCard from "@components/ProductCard.astro";
import SubscriptionCard from "@components/SubscriptionCard.astro";
import { site } from "@data/site";
import { menu, subscriptions } from "@data/menu";
import { values } from "@data/values";

const featuredSlugs = ["himbasha", "buna-cookies", "buna"];
const featured = featuredSlugs
  .map((slug) => menu.find((m) => m.slug === slug))
  .filter((m): m is (typeof menu)[number] => Boolean(m));
const weekly = subscriptions.find((s) => s.slug === "weekly-table")!;
---
<Base>
  <!-- ===================== HERO ===================== -->
  <section class="hero">
    <div class="hero__glow" aria-hidden="true"></div>
    <div class="container hero__inner">
      <div class="hero__copy">
        <p class="eyebrow" data-reveal>
          <span lang="am">{site.amharic.bread}</span> · {site.location.city}, {site.location.regionCode}
        </p>
        <h1 data-reveal data-reveal-delay="60">
          The breads of home,<br /><span class="hero__accent">baked for everyone.</span>
        </h1>
        <p class="lede hero__lede" data-reveal data-reveal-delay="140">
          {site.shortDescription}
        </p>
        <div class="hero__actions" data-reveal data-reveal-delay="220">
          <a href="/menu" class="btn btn--primary btn--lg">
            Order fresh bread <Icon name="arrow" size={20} />
          </a>
          <a href="/subscriptions" class="btn btn--ghost btn--lg">Join a bread box</a>
        </div>
        <ul class="hero__proof" data-reveal data-reveal-delay="300">
          <li><Icon name="leaf" size={18} /> Stone-milled teff</li>
          <li><Icon name="hands" size={18} /> A living wage for every baker</li>
          <li><Icon name="gift" size={18} /> A box feeds a neighbor</li>
        </ul>
      </div>

      <div class="hero__art" data-reveal data-reveal-delay="120">
        <div class="hero__plate drift">
          <img
            src="/images/hero.jpg"
            alt="A spread of freshly baked Eritrean and Ethiopian breads — cinnamon-raisin himbasha, honeyed dabo, and a cheesy dabo formaggio — on a warm wooden table."
            width="720"
            height="820"
            fetchpriority="high"
            decoding="async"
          />
        </div>
        <div class="hero__chip hero__chip--1">
          <strong lang="am">{site.amharic.welcome}</strong><span>welcome</span>
        </div>
        <div class="hero__chip hero__chip--2">
          <Icon name="star" size={16} /><span>Baked this morning</span>
        </div>
      </div>
    </div>
    <div class="hero__wave" aria-hidden="true"></div>
  </section>

  <!-- ===================== VALUES ===================== -->
  <section class="section values">
    <div class="container">
      <div class="section-head center" data-reveal>
        <p class="eyebrow">What we keep</p>
        <h2>A bakery answers to its neighbors.</h2>
        <p class="lede prose center">
          We measure a good week less by what we sold than by who sat down. These
          are the promises we are most careful about.
        </p>
      </div>
      <div class="grid cols-3 values__grid">
        {
          values.map((v, i) => (
            <article class="value" data-reveal data-reveal-delay={i * 70}>
              <span class="value__icon"><Icon name={v.icon} size={26} /></span>
              <h3>{v.title}</h3>
              <p>{v.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== FEATURED MENU ===================== -->
  <section class="section featured">
    <div class="container">
      <div class="section-head split" data-reveal>
        <div>
          <p class="eyebrow">From the oven</p>
          <h2>This week's table</h2>
        </div>
        <a href="/menu" class="btn btn--ghost">See the full menu <Icon name="arrow" size={18} /></a>
      </div>
      <div class="grid cols-3">
        {featured.map((item, i) => <ProductCard item={item} delay={i * 70} />)}
      </div>
    </div>
  </section>

  <!-- ===================== SUBSCRIPTION TEASER ===================== -->
  <section class="section sub-teaser">
    <div class="container sub-teaser__inner">
      <div class="sub-teaser__copy" data-reveal>
        <p class="eyebrow">Bread boxes</p>
        <h2>Set a standing place at the table.</h2>
        <p class="lede">
          A rotating box of the week's best baking — delivered or ready for pickup.
          A portion of every box bakes bread for a neighbor going without.
        </p>
        <ul class="sub-teaser__list">
          <li><Icon name="check" size={20} /> Pause, skip, or cancel whenever life shifts</li>
          <li><Icon name="check" size={20} /> Always fresh, never frozen</li>
          <li><Icon name="check" size={20} /> The same care, every single week</li>
        </ul>
        <a href="/subscriptions" class="btn btn--gold btn--lg">Explore the boxes</a>
      </div>
      <div class="sub-teaser__card">
        <SubscriptionCard item={weekly} featured />
      </div>
    </div>
  </section>

  <!-- ===================== STORY STRIP ===================== -->
  <section class="section story-strip">
    <div class="container story-strip__inner" data-reveal>
      <blockquote>
        <p>
          “It started the way most good things do — with too much bread and not
          enough people to give it to.”
        </p>
        <footer>
          <a href="/our-story" class="btn btn--ghost">Read our story <Icon name="arrow" size={18} /></a>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- ===================== VISIT CTA ===================== -->
  <section class="section visit-cta">
    <div class="container visit-cta__inner" data-reveal>
      <div>
        <p class="eyebrow">Come by</p>
        <h2>There's a warm loaf with your name on it.</h2>
        <p class="lede prose">
          Find us in {site.location.neighborhood}, {site.location.city}. Order ahead
          for pickup, or just follow the cardamom.
        </p>
      </div>
      <div class="visit-cta__actions">
        <a href="/visit" class="btn btn--primary btn--lg">Hours &amp; directions</a>
        <a href={site.contact.phoneHref} class="btn btn--ghost btn--lg">
          <Icon name="phone" size={18} /> {site.contact.phone}
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ---- hero ---- */
  .hero {
    position: relative;
    padding-top: clamp(2rem, 5vw, 4rem);
    overflow: clip;
  }
  .hero__glow {
    position: absolute;
    inset: -20% -10% auto;
    height: 70%;
    background: radial-gradient(
        ellipse at 30% 30%,
        color-mix(in oklab, var(--gold) 35%, transparent),
        transparent 60%
      ),
      radial-gradient(
        ellipse at 80% 10%,
        color-mix(in oklab, var(--berbere) 22%, transparent),
        transparent 55%
      );
    filter: blur(10px);
    z-index: -1;
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
    gap: clamp(1.5rem, 5vw, 4rem);
    padding-block: clamp(1.5rem, 4vw, 3.5rem);
  }
  .hero__accent {
    color: var(--berbere);
    font-style: italic;
    font-weight: 500;
  }
  .hero__lede {
    max-width: 46ch;
    margin-top: 1.2rem;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.8rem;
  }
  .hero__proof {
    list-style: none;
    padding: 0;
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.6rem;
    color: var(--ink-soft);
    font-weight: 550;
    font-size: var(--step--1);
  }
  .hero__proof li {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .hero__proof :global(svg) {
    color: var(--green-bright);
  }

  .hero__art {
    position: relative;
    display: grid;
    place-items: center;
  }
  .hero__plate {
    width: min(100%, 30rem);
    aspect-ratio: 1 / 1.05;
    border-radius: 50% 50% 48% 52% / 52% 50% 50% 48%;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 6px solid var(--cream);
    background: var(--parchment-deep);
  }
  .hero__plate img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero__chip {
    position: absolute;
    background: var(--cream);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-md);
    padding: 0.6rem 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--step--1);
    font-weight: 600;
  }
  .hero__chip strong {
    font-family: var(--font-display);
    color: var(--berbere);
    font-size: 1.05rem;
    white-space: nowrap;
  }
  .hero__chip span {
    color: var(--ink-soft);
  }
  .hero__chip--1 {
    top: 8%;
    left: -2%;
    animation: drift 7s var(--ease) infinite;
  }
  .hero__chip--2 {
    bottom: 10%;
    right: -3%;
    color: var(--green);
    animation: drift 8.5s var(--ease) infinite reverse;
  }
  .hero__chip--2 :global(svg) {
    color: var(--gold-deep);
  }

  @media (max-width: 880px) {
    .hero__inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero__lede,
    .prose {
      margin-inline: auto;
    }
    .hero__actions,
    .hero__proof {
      justify-content: center;
    }
    .hero__art {
      order: -1;
      margin-bottom: 1rem;
    }
  }

  /* section heads */
  .section-head {
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .section-head h2 {
    margin-top: 0.4rem;
  }
  .section-head.center .lede {
    margin-top: 0.8rem;
  }
  .section-head.split {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* values */
  .values {
    background: linear-gradient(
      180deg,
      transparent,
      color-mix(in oklab, var(--green) 6%, transparent)
    );
  }
  .value {
    padding: 1.6rem;
    border-radius: var(--radius-lg);
    background: var(--surface);
    border: 1px solid color-mix(in oklab, var(--ink) 7%, transparent);
    box-shadow: var(--shadow-sm);
    transition: transform 0.4s var(--ease), box-shadow 0.4s var(--ease);
  }
  .value:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
  }
  .value__icon {
    display: grid;
    place-items: center;
    width: 3.2rem;
    height: 3.2rem;
    border-radius: 16px;
    background: color-mix(in oklab, var(--gold) 22%, var(--cream));
    color: var(--gold-deep);
    margin-bottom: 1rem;
  }
  .value h3 {
    font-size: var(--step-1);
    margin-bottom: 0.4rem;
  }
  .value p {
    color: var(--muted);
  }

  /* subscription teaser */
  .sub-teaser__inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: center;
  }
  .sub-teaser__list {
    list-style: none;
    padding: 0;
    margin: 1.4rem 0 2rem;
    display: grid;
    gap: 0.7rem;
  }
  .sub-teaser__list li {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--ink-soft);
  }
  .sub-teaser__list :global(svg) {
    color: var(--green-bright);
    flex-shrink: 0;
  }
  .sub-teaser__card {
    max-width: 26rem;
    margin-inline: auto;
  }
  @media (max-width: 880px) {
    .sub-teaser__inner {
      grid-template-columns: 1fr;
    }
  }

  /* story strip */
  .story-strip__inner {
    background: var(--coffee);
    color: var(--cream);
    border-radius: var(--radius-lg);
    padding: clamp(2.2rem, 6vw, 4rem);
    text-align: center;
    background-image: radial-gradient(
      circle at 80% 120%,
      color-mix(in oklab, var(--gold) 40%, transparent),
      transparent 50%
    );
  }
  .story-strip blockquote {
    max-width: 40ch;
    margin-inline: auto;
  }
  .story-strip blockquote p {
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-style: italic;
    line-height: 1.2;
    color: var(--cream);
  }
  .story-strip footer {
    margin-top: 1.8rem;
  }
  .story-strip .btn--ghost {
    color: var(--cream);
    border-color: color-mix(in oklab, var(--cream) 40%, transparent);
  }

  /* visit cta */
  .visit-cta__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    padding: clamp(2rem, 5vw, 3.5rem);
    background: var(--surface);
    border: 1px solid color-mix(in oklab, var(--ink) 8%, transparent);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }
  .visit-cta__actions {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }
</style>
