---
import "@/styles/global.css";
import SEO from "@components/SEO.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import CartDrawer from "@components/CartDrawer.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}
const { title, description, image, noindex } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <SEO title={title} description={description} image={image} noindex={noindex} />
    <!-- Mark JS available before paint so scroll-reveal can hide its initial
         state. No-JS visitors keep all content fully visible. -->
    <script is:inline>document.documentElement.classList.add("js");</script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <CartDrawer />
    <script>
      import "../scripts/main.ts";
    </script>
  </body>
</html>
