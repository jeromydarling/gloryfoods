---
import { site } from "@data/site";
import Icon from "@components/Icon.astro";
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <p class="footer-amharic" lang="am">{site.amharic.welcome}</p>
        <p class="footer-name">{site.name}</p>
        <p class="footer-tag">{site.tagline}</p>
        <div class="footer-social" aria-label="Social media">
          <a href={site.social.instagram} aria-label="Instagram" rel="me noopener" target="_blank">
            <Icon name="instagram" size={20} />
          </a>
          <a href={site.social.facebook} aria-label="Facebook" rel="me noopener" target="_blank">
            <Icon name="facebook" size={20} />
          </a>
        </div>
      </div>

      <nav class="footer-col" aria-label="Explore">
        <h2>Explore</h2>
        <ul>
          <li><a href="/menu">Menu</a></li>
          <li><a href="/subscriptions">Bread Boxes</a></li>
          <li><a href="/our-story">Our Story</a></li>
          <li><a href="/visit">Visit & Hours</a></li>
        </ul>
      </nav>

      <div class="footer-col">
        <h2>Find us</h2>
        <ul class="footer-contact">
          <li><Icon name="pin" size={18} /><span>{site.location.addressLine}</span></li>
          <li>
            <Icon name="mail" size={18} />
            <a href={`mailto:${site.contact.email}`}>{site.contact.email}</a>
          </li>
          <li>
            <Icon name="phone" size={18} />
            <a href={site.contact.phoneHref}>{site.contact.phone}</a>
          </li>
        </ul>
      </div>

      <div class="footer-col footer-newsletter">
        <h2>The standing invitation</h2>
        <p>A short note when something new comes out of the oven. No noise, ever.</p>
        <form data-newsletter class="newsletter-form" novalidate>
          <label class="visually-hidden" for="footer-email">Email address</label>
          <input
            type="email"
            id="footer-email"
            name="email"
            placeholder="you@email.com"
            autocomplete="email"
            required
          />
          <button type="submit" class="btn btn--gold" aria-label="Subscribe">
            <Icon name="arrow" size={20} />
          </button>
        </form>
        <p class="newsletter-status" data-newsletter-status role="status" aria-live="polite"></p>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© {year} {site.legalName}. Baked with care in {site.location.city}, {site.location.regionCode}.</p>
      <p class="footer-credo">A place is set for everyone.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-2xl);
    background: var(--coffee);
    color: color-mix(in oklab, var(--parchment) 88%, var(--coffee));
    padding-block: clamp(3rem, 7vw, 5rem) 2rem;
    background-image: radial-gradient(
      circle at 85% 0%,
      color-mix(in oklab, var(--berbere) 40%, transparent),
      transparent 45%
    );
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1.3fr;
    gap: clamp(1.5rem, 4vw, 3rem);
  }
  @media (max-width: 820px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand,
    .footer-newsletter {
      grid-column: 1 / -1;
    }
  }
  .footer-amharic {
    font-family: var(--font-display);
    color: var(--gold);
    font-size: 1.4rem;
    margin-bottom: 0.2rem;
  }
  .footer-name {
    font-family: var(--font-display);
    font-size: var(--step-2);
    color: var(--cream);
    line-height: 1;
  }
  .footer-tag {
    color: color-mix(in oklab, var(--parchment) 70%, var(--coffee));
    margin-top: 0.4rem;
    max-width: 26ch;
  }
  .footer-social {
    display: flex;
    gap: 0.6rem;
    margin-top: 1.2rem;
  }
  .footer-social a {
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    color: var(--cream);
    border: 1px solid color-mix(in oklab, var(--parchment) 30%, transparent);
    transition: background-color 0.2s var(--ease), transform 0.2s var(--ease);
  }
  .footer-social a:hover {
    background: var(--gold);
    color: var(--coffee);
    transform: translateY(-2px);
  }
  .footer-col h2 {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
    font-weight: 700;
  }
  .footer-col ul {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }
  .footer-col a {
    color: color-mix(in oklab, var(--parchment) 85%, var(--coffee));
    text-decoration: none;
  }
  .footer-col a:hover {
    color: var(--gold);
  }
  .footer-contact li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .footer-newsletter p {
    color: color-mix(in oklab, var(--parchment) 72%, var(--coffee));
    margin-bottom: 1rem;
    max-width: 32ch;
  }
  .newsletter-form {
    display: flex;
    gap: 0.5rem;
  }
  .newsletter-form input {
    flex: 1;
    padding: 0.75em 1em;
    border-radius: var(--radius-pill);
    border: 1px solid color-mix(in oklab, var(--parchment) 30%, transparent);
    background: color-mix(in oklab, var(--cream) 12%, transparent);
    color: var(--cream);
  }
  .newsletter-form input::placeholder {
    color: color-mix(in oklab, var(--parchment) 55%, transparent);
  }
  .newsletter-form .btn {
    padding-inline: 1.1em;
  }
  .newsletter-status {
    min-height: 1.2em;
    margin-top: 0.6rem;
    font-size: var(--step--1);
    color: var(--gold);
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: clamp(2rem, 5vw, 3.5rem);
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in oklab, var(--parchment) 18%, transparent);
    font-size: var(--step--1);
    color: color-mix(in oklab, var(--parchment) 62%, var(--coffee));
  }
  .footer-credo {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--gold);
  }
</style>
