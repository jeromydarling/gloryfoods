};

const d = paths[name] ?? "";
const filled = name === "facebook" || name === "instagram";
---
<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={filled ? 1.6 : 1.8}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  role={title ? "img" : undefined}
  aria-hidden={title ? undefined : "true"}
  aria-label={title}
  set:html={(title ? `<title>${title}</title>` : "") + d}
/>
