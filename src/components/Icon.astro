---
/**
 * Inline SVG icon set. Decorative by default (aria-hidden); pass a `title`
 * to expose an accessible label. Stroke icons inherit `currentColor`.
 */
interface Props {
  name: string;
  size?: number;
  title?: string;
  class?: string;
}
const { name, size = 24, title, class: className } = Astro.props;

const paths: Record<string, string> = {
