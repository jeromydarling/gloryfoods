  bread:
    '<path d="M5.5 14.5C3.6 14.5 3 13 3 11.7 3 9 6.6 7 12 7s9 2 9 4.7c0 1.3-.6 2.8-2.5 2.8M5.5 14.5 7 19h10l1.5-4.5M5.5 14.5h13"/>',
  hands:
    '<path d="M7 11V6.5a1.5 1.5 0 0 1 3 0V11m0-1V5.5a1.5 1.5 0 0 1 3 0V11m0-.5V6a1.5 1.5 0 0 1 3 0v6.5c0 3.6-2.4 6.5-6 6.5s-6-2-6.8-4.5l-1-3a1.4 1.4 0 0 1 2.4-1.3L7 12.5"/>',
  gift:
    '<path d="M20 12v8a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-8M3 8h18v4H3zM12 8v13M12 8S10.5 4 8.2 4 5.5 8 8 8h4Zm0 0s1.5-4 3.8-4S18.5 8 16 8h-4Z"/>',
  wheat:
    '<path d="M12 22V9m0 0c0-2 1-3 3-3.5C14.5 7.5 13.5 9 12 9Zm0 0c0-2-1-3-3-3.5C9.5 7.5 10.5 9 12 9Zm0-5c0-2 1-3 3-3.5C14.5 2.5 13.5 4 12 4Zm0 0c0-2-1-3-3-3.5C9.5 2.5 10.5 4 12 4Zm0 9c0-2 1-3 3-3.5-.5 2-1.5 3.5-3 3.5Zm0 0c0-2-1-3-3-3.5.5 2 1.5 3.5 3 3.5Z"/>',
  community:
    '<path d="M9 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm9 1a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5ZM3 20c0-3.3 2.7-6 6-6s6 2.7 6 6M15.5 14.5c2.5 0 4.5 1.9 4.5 4.5"/>',
  // ui
  cart: '<path d="M3 4h2l2.4 12.2a1 1 0 0 0 1 .8h8.7a1 1 0 0 0 1-.8L21 8H6M9 21a1 1 0 1 0 0-2 1 1 0 0 0 0 2Zm9 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z"/>',
  menu: '<path d="M4 7h16M4 12h16M4 17h16"/>',
  close: '<path d="M6 6l12 12M18 6 6 18"/>',
  plus: '<path d="M12 5v14M5 12h14"/>',
  minus: '<path d="M5 12h14"/>',
  trash:
    '<path d="M4 7h16M9 7V5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2m2 0v12a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V7"/>',
  arrow: '<path d="M5 12h14M13 6l6 6-6 6"/>',
  check: '<path d="M4 12.5 9 17.5 20 6.5"/>',
  star: '<path d="M12 3.5l2.6 5.3 5.9.9-4.3 4.1 1 5.8L12 17l-5.2 2.7 1-5.8L3.5 9.7l5.9-.9L12 3.5Z"/>',
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  pin: '<path d="M12 21s7-5.7 7-11a7 7 0 1 0-14 0c0 5.3 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>',
  phone:
    '<path d="M5 4h3l1.5 5-2 1.5a12 12 0 0 0 6 6l1.5-2 5 1.5v3a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2Z"/>',
  instagram:
    '<rect x="3.5" y="3.5" width="17" height="17" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="1" fill="currentColor" stroke="none"/>',
  facebook:
    '<path d="M14 8.5h2.5V5.5H14c-2 0-3.5 1.5-3.5 3.5v2H8v3h2.5v6.5h3V14H16l.5-3h-3V9.5c0-.6.4-1 1-1Z" fill="currentColor" stroke="none"/>',
  leaf: '<path d="M5 19C5 11 11 5 19 5c0 8-6 14-14 14Zm0 0 7-7"/>',
